/**
 * DownloadModelTaskSpec — lightweight coverage of the CommandBox task shell.
 *
 * The task is a thin orchestration wrapper around `ModelAssetManager` (which
 * has its own deep spec). Here we just confirm:
 *   - The task class instantiates and exposes `run` / `list`.
 *   - `list` enumerates every registered model by name.
 *   - `run` in a no-op scenario (assets already present) succeeds and
 *     emits the success output path.
 *   - `run` with a missing-asset scenario in manual mode surfaces the
 *     error via `print.redLine`.
 *
 * We inject a captured `print` stub so we can assert what the operator
 * would see at the console.
 */
class extends="testbox.system.BaseSpec" {

    function beforeAll() {
        variables.tmpRoot = expandPath( "./.tmp-task-tests/" );
        if ( directoryExists( variables.tmpRoot ) ) {
            directoryDelete( variables.tmpRoot, true );
        }
        directoryCreate( variables.tmpRoot, true );
    }

    function afterAll() {
        if ( directoryExists( variables.tmpRoot ) ) {
            directoryDelete( variables.tmpRoot, true );
        }
    }

    function run() {

        describe( "DownloadModel task", function() {

            it( "instantiates and exposes the expected methods", function() {
                var t = new bxAiSentinelOnnx.tasks.DownloadModel();
                expect( t ).toHaveKey( "run"  );
                expect( t ).toHaveKey( "list" );
            } );

            it( "list() prints each registered model", function() {
                var capture = _capturePrint();
                var t = new bxAiSentinelOnnx.tasks.DownloadModel();
                t.print = capture.print;

                t.list();

                var joined = arrayToList( capture.buffer, char( 10 ) );
                expect( joined ).toInclude( "Registered models:" );
                expect( joined ).toInclude( "gliner-pii-v1" );
                expect( joined ).toInclude( "piiranha-pii-v1" );
            } );

            it( "run() reports success when assets are already present", function() {
                var dir = variables.tmpRoot & "task-happy/";
                directoryCreate( dir, true );
                fileWrite( dir & "model.onnx",     "fake" );
                fileWrite( dir & "tokenizer.json", "{}"    );

                var capture = _capturePrint();
                var t = new bxAiSentinelOnnx.tasks.DownloadModel();
                t.print = capture.print;

                t.run(
                    modelName = "does-not-matter-files-already-present",
                    modelPath = dir,
                    assetMode = "manual"
                );

                var joined = arrayToList( capture.buffer, char( 10 ) );
                expect( joined ).toInclude( "already present and valid" );
            } );

            it( "run() surfaces a clear error in manual mode when files are missing", function() {
                var dir = variables.tmpRoot & "task-missing/";
                directoryCreate( dir, true );

                var capture = _capturePrint();
                var t = new bxAiSentinelOnnx.tasks.DownloadModel();
                t.print = capture.print;

                try {
                    t.run(
                        modelName = "gliner-pii-v1",
                        modelPath = dir,
                        assetMode = "manual"
                    );
                    fail( "Expected task to rethrow the MissingAssets exception" );
                } catch ( bxAiSentinelOnnx.MissingAssets e ) {
                    // Expected — the task prints first, then rethrows.
                    var joined = arrayToList( capture.buffer, char( 10 ) );
                    expect( joined ).toInclude( "Download failed" );
                }
            } );

        } );

    }

    /**
     * Capture-and-collect print stub. Returns a struct with the `print`
     * object (struct of closures) and a `buffer` array that accumulates
     * every line emitted. Tests assert on the joined buffer.
     */
    private struct function _capturePrint() {
        var buffer = [];
        var capture = function( msg = "" ) {
            buffer.append( msg );
        };
        return {
            "print" : {
                "line"       : capture,
                "greenLine"  : capture,
                "yellowLine" : capture,
                "redLine"    : capture
            },
            "buffer" : buffer
        };
    }

}
