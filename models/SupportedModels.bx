/**
 * SupportedModels — authoritative registry of model metadata.
 *
 * For each known `modelName`, returns the source URL, expected SHA-256,
 * tokenizer source + checksum, id2label map, label→Sentinel mapping, and
 * license / provenance info. `ModelAssetManager` consumes this to download
 * and validate; `OnnxNerDetector` consumes it to populate its decoder.
 *
 * **Checksum policy.** Entries shipped with empty `modelChecksum` /
 * `tokenizerChecksum` are flagged `verified: false` — the maintainer has
 * not yet personally downloaded + hashed the files. `ModelAssetManager`
 * refuses to `auto-download` an unverified entry unless the operator
 * explicitly passes `acceptUnverified: true`. Once a maintainer has
 * downloaded + hashed a model, they edit this file to add the real
 * SHA-256 values and flip `verified: true`, so future auto-downloads are
 * tamper-checked.
 *
 * License policy.  Every entry declares a `license` and `licenseStatus`.
 * `licenseStatus: "unverified"` marks models whose redistribution terms
 * we haven't confirmed — `ModelAssetManager` also refuses to auto-download
 * these unless the operator explicitly opts in. Manual mode (operator
 * places files themselves) always works regardless of license status.
 */
class singleton {

    property name="registry" type="struct";

    function init() {
        variables.registry = _buildRegistry();
        return this;
    }

    /**
     * Look up a model's full metadata by its registered name.
     * Returns `{}` if the name isn't registered.
     */
    struct function get( required string modelName ) {
        return structKeyExists( variables.registry, arguments.modelName )
            ? duplicate( variables.registry[ arguments.modelName ] )
            : {};
    }

    /**
     * Does the registry know about this model?
     */
    boolean function has( required string modelName ) {
        return structKeyExists( variables.registry, arguments.modelName );
    }

    /**
     * List every registered model name. Useful for the `download-model`
     * task's `list` subcommand.
     */
    array function list() {
        return structKeyArray( variables.registry );
    }

    // ─── Registry data ───────────────────────────────────────────────────

    private struct function _buildRegistry() {
        return {

            "gliner-pii-v1" : {
                "displayName"        : "GLiNER multi-PII v1",
                "description"        : "Zero-shot-capable NER fine-tuned on PII across 6 languages. Apache 2.0.",
                // ONNX export lives under onnx-community, not the original author's repo.
                // `urchade/gliner_multi_pii-v1` ships only pytorch_model.bin and has no
                // onnx/ subdirectory or tokenizer.json. Maintainer needs to verify + pin
                // SHA-256 checksums before flipping `verified: true`.
                "modelSource"        : "https://huggingface.co/onnx-community/gliner_multi_pii-v1/resolve/main/onnx/model.onnx",
                "tokenizerSource"    : "https://huggingface.co/onnx-community/gliner_multi_pii-v1/resolve/main/tokenizer.json",
                "modelChecksum"      : "",
                "tokenizerChecksum"  : "",
                "verified"           : false,
                "license"            : "Apache-2.0",
                "licenseStatus"      : "verified",
                "licenseUrl"         : "https://huggingface.co/urchade/gliner_multi_pii-v1",
                "contextLength"      : 384,
                "decoderStrategy"    : "gliner-span",
                // Placeholder — GLiNER-PII-v1's label schema is span-based, not BIO. EntityDecoder's
                // current BIO implementation won't decode it correctly until a GLiNER-specific adapter
                // is added. See DEV-NOTES/discovery-log.md.
                "id2label"           : {},
                "labelToSentinel"    : {
                    "person"                : "PII_PERSON_NAME",
                    "organization"          : "PII_ORGANIZATION",
                    "phone_number"          : "PII_PHONE",
                    "address"               : "PII_ADDRESS",
                    "passport_number"       : "PII_PASSPORT",
                    "email"                 : "PII_EMAIL",
                    "credit_card_number"    : "PII_CREDIT_CARD",
                    "social_security_number": "PII_SSN",
                    "health_insurance_id"   : "PII_HEALTH_INSURANCE",
                    "date_of_birth"         : "PII_DOB",
                    "mobile_phone_number"   : "PII_PHONE",
                    "bank_account_number"   : "PII_BANK_ACCOUNT",
                    "medication"            : "PII_MEDICATION",
                    "cpf"                   : "PII_NATIONAL_ID",
                    "driver_license_number" : "PII_DRIVERS_LICENSE",
                    "tax_identification_number" : "PII_TAX_ID",
                    "medical_condition"     : "PII_MEDICAL_CONDITION",
                    "identity_card_number"  : "PII_NATIONAL_ID",
                    "national_id"           : "PII_NATIONAL_ID",
                    "ip_address"            : "PII_IP_ADDRESS",
                    "iban"                  : "PII_BANK_ACCOUNT"
                }
            },

            "piiranha-pii-v1" : {
                "displayName"        : "Piiranha v1 (detect-personal-information)",
                "description"        : "Fine-tuned mdeberta-v3 token classifier. 98.5% F1 on 17 PII types across 6 languages. Uses pure I-tagging (no B- prefix); decoder must handle adjacent-same-label spans.",
                "modelSource"        : "https://huggingface.co/onnx-community/piiranha-v1-detect-personal-information-ONNX/resolve/main/onnx/model.onnx",
                "tokenizerSource"    : "https://huggingface.co/iiiorg/piiranha-v1-detect-personal-information/resolve/main/tokenizer.json",
                "modelChecksum"      : "",
                "tokenizerChecksum"  : "",
                "verified"           : false,
                // License on the original iiiorg repo is not publicly documented.
                // Auto-download is gated until the maintainer verifies and updates this.
                "license"            : "unknown",
                "licenseStatus"      : "unverified",
                "licenseUrl"         : "https://huggingface.co/iiiorg/piiranha-v1-detect-personal-information",
                "contextLength"      : 256,
                "decoderStrategy"    : "io",
                // Verified against the model's actual config.json on 2026-04-19.
                // 18 classes total; index 17 is the "no entity" label "O".
                // Every entity label is `I-...` — there are NO B- labels in this
                // model, contrary to the prior assumption. EntityDecoder must
                // treat I-LABEL as opening when no matching span is open.
                "id2label"           : {
                    0  : "I-ACCOUNTNUM",
                    1  : "I-BUILDINGNUM",
                    2  : "I-CITY",
                    3  : "I-CREDITCARDNUMBER",
                    4  : "I-DATEOFBIRTH",
                    5  : "I-DRIVERLICENSENUM",
                    6  : "I-EMAIL",
                    7  : "I-GIVENNAME",
                    8  : "I-IDCARDNUM",
                    9  : "I-PASSWORD",
                    10 : "I-SOCIALNUM",
                    11 : "I-STREET",
                    12 : "I-SURNAME",
                    13 : "I-TAXNUM",
                    14 : "I-TELEPHONENUM",
                    15 : "I-USERNAME",
                    16 : "I-ZIPCODE",
                    17 : "O"
                },
                "labelToSentinel"    : {
                    "ACCOUNTNUM"       : "PII_BANK_ACCOUNT",
                    "BUILDINGNUM"      : "PII_ADDRESS",
                    "CITY"             : "PII_ADDRESS",
                    "CREDITCARDNUMBER" : "PII_CREDIT_CARD",
                    "DATEOFBIRTH"      : "PII_DOB",
                    "DRIVERLICENSENUM" : "PII_DRIVERS_LICENSE",
                    "EMAIL"            : "PII_EMAIL",
                    "GIVENNAME"        : "PII_PERSON_NAME",
                    "IDCARDNUM"        : "PII_NATIONAL_ID",
                    "PASSWORD"         : "PII_PASSWORD",
                    "SOCIALNUM"        : "PII_SSN",
                    "STREET"           : "PII_ADDRESS",
                    "SURNAME"          : "PII_PERSON_NAME",
                    "TAXNUM"           : "PII_TAX_ID",
                    "TELEPHONENUM"     : "PII_PHONE",
                    "USERNAME"         : "PII_USERNAME",
                    "ZIPCODE"          : "PII_ADDRESS"
                }
            }

        };
    }

}
