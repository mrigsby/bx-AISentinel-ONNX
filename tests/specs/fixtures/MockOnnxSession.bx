/**
 * MockOnnxSession — stands in for `OnnxSession` in OnnxNerDetector specs
 * so we can exercise the full scan() pipeline without JARs, ONNX Runtime,
 * or a real model on disk.
 *
 * Construct with the tokenization + logits the test wants to feed, and
 * OnnxNerDetector will produce decoded Hit structs from those.
 */
class {

    property name="tokens" type="struct";
    property name="logits" type="array";
    property name="loaded" type="boolean" default="true";

    function init(
                 struct  tokens = { "inputIds": [], "attentionMask": [], "offsetMapping": [] },
                 array   logits = [],
                 boolean loaded = true
    ) {
        variables.tokens = arguments.tokens;
        variables.logits = arguments.logits;
        variables.loaded = arguments.loaded;
        return this;
    }

    boolean function isReady()       { return variables.loaded; }
    boolean function ensureLoaded()  { return variables.loaded; }

    struct function tokenize( required string text ) {
        return variables.tokens;
    }

    array function runInference( required array inputIds, required array attentionMask ) {
        // Wrap in batch dimension to match real ONNX Runtime output shape
        // [batch=1, seqLen, numLabels]. OnnxNerDetector._normalizeLogits
        // peels this dimension off, so the mock has to ship it for parity
        // with production behavior. Specs continue to construct logits as
        // a clean 2-D [seqLen][numLabels] array — the wrap is invisible
        // to test authors.
        return [ variables.logits ];
    }

    struct function getStatus() {
        return {
            "loaded"        : variables.loaded,
            "modelPath"     : "(mock)",
            "tokenizerPath" : "(mock)",
            "loadError"     : ""
        };
    }

}
