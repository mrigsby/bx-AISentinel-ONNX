/**
 * OnnxNerDetectorSpec — unit coverage of the detector's Phase 4 surface.
 *
 * Verifies:
 *   - IDetector@1.0.0 contract surface.
 *   - ModelAssetManager integration — default construction, no-assets
 *     graceful-empty scan, validateAssets shape.
 *   - Full pipeline via MockOnnxSession (tokenize → inference → decode).
 *   - Convenience API (extractEntities, containsPii, redactInline).
 *   - Label-gated real-model integration (skipped unless run with
 *     `label="real-model"` AND the JARs / model are actually present).
 */
class extends="testbox.system.BaseSpec" {

    function run() {

        describe( "OnnxNerDetector — IDetector@1.0.0 contract surface", function() {

            it( "exposes the required contract methods", function() {
                var d = new bxAISentinelONNX.models.OnnxNerDetector();
                expect( d ).toHaveKey( "scan" );
                expect( d ).toHaveKey( "getPriority" );
                expect( d ).toHaveKey( "getSourceName" );
                expect( d ).toHaveKey( "getContractVersion" );
            } );

            it( "declares contract version 1.0.0", function() {
                var d = new bxAISentinelONNX.models.OnnxNerDetector();
                expect( d.getContractVersion() ).toBe( "1.0.0" );
            } );

            it( "reports its source name as OnnxNerDetector", function() {
                var d = new bxAISentinelONNX.models.OnnxNerDetector();
                expect( d.getSourceName() ).toBe( "OnnxNerDetector" );
            } );

            it( "reports a positive numeric priority", function() {
                var d = new bxAISentinelONNX.models.OnnxNerDetector();
                expect( d.getPriority() ).toBeGT( 0 );
            } );

        } );

        describe( "OnnxNerDetector.scan — no assets present (default state)", function() {

            it( "returns an empty array when modelPath is unset", function() {
                var d = new bxAISentinelONNX.models.OnnxNerDetector();
                expect( d.scan( "Alice Martinez lives in Madrid." ) ).toHaveLength( 0 );
            } );

            it( "returns an empty array when modelPath is a missing directory", function() {
                var d = new bxAISentinelONNX.models.OnnxNerDetector( settings: {
                    "modelPath" : "/nope/does/not/exist/"
                } );
                expect( d.scan( "random text" ) ).toHaveLength( 0 );
            } );

            it( "handles empty input without throwing", function() {
                var d = new bxAISentinelONNX.models.OnnxNerDetector();
                expect( d.scan( "" ) ).toHaveLength( 0 );
            } );

            it( "returns empty when session reports not-loaded (injected mock)", function() {
                var session = new tests.specs.fixtures.MockOnnxSession( loaded = false );
                var d = new bxAISentinelONNX.models.OnnxNerDetector( settings: {
                    "session" : session
                } );
                expect( d.scan( "irrelevant" ) ).toHaveLength( 0 );
            } );

        } );

        describe( "OnnxNerDetector.validateAssets", function() {

            it( "returns a struct aggregating assetManager + session status", function() {
                var d = new bxAISentinelONNX.models.OnnxNerDetector( settings: {
                    "modelPath" : "/fake/path/"
                } );
                var status = d.validateAssets();
                expect( status ).toHaveKey( "ok" );
                expect( status ).toHaveKey( "sessionLoaded" );    // v0.4.0+
                expect( status ).toHaveKey( "lastScanError" );    // v0.4.0+
                expect( status ).toHaveKey( "assetManager" );
                expect( status ).toHaveKey( "session" );
                expect( status.assetManager ).toHaveKey( "ok" );
                expect( status.assetManager ).toHaveKey( "modelFile" );
                expect( status.assetManager ).toHaveKey( "missingFiles" );
                expect( status.session ).toHaveKey( "loaded" );
            } );

            it( "reports ok=false when assets are missing", function() {
                var d = new bxAISentinelONNX.models.OnnxNerDetector( settings: {
                    "modelPath" : "/fake/path/"
                } );
                var status = d.validateAssets();
                expect( status.ok                   ).toBeFalse();
                expect( status.assetManager.ok      ).toBeFalse();
                expect( status.session.loaded       ).toBeFalse();
                expect( status.sessionLoaded        ).toBeFalse();
                expect( status.lastScanError        ).toBe( "" );
            } );

            it( "validateAssets has NO side effects — does NOT trigger model load", function() {
                // Health-check guarantee: prior versions had `ok` require
                // session.loaded, which was structurally false until something
                // else triggered ensureLoaded(). New contract: validateAssets
                // reports state, never causes loading. To force load at
                // construction, hosts pass eagerInit: true.
                var d = new bxAISentinelONNX.models.OnnxNerDetector( settings: {
                    "modelPath" : "/fake/path/",
                    "id2label"  : { 0: "O" },        // make assets-only ok possible
                    "session"   : new tests.specs.fixtures.MockOnnxSession( loaded = false )
                } );
                d.validateAssets();
                d.validateAssets();
                d.validateAssets();
                // sessionLoaded stays false across multiple validateAssets calls.
                expect( d.validateAssets().sessionLoaded ).toBeFalse();
            } );

            it( "getLastScanError returns empty string when no scan has run", function() {
                var d = new bxAISentinelONNX.models.OnnxNerDetector( settings: {
                    "modelPath" : "/fake/path/"
                } );
                expect( d.getLastScanError() ).toBe( "" );
            } );

        } );

        describe( "OnnxNerDetector.scan — full pipeline with mock session", function() {

            it( "tokenizes, runs inference, and decodes into Sentinel Hit structs", function() {
                // Offsets are 0-based with exclusive end (DJL/HF convention).
                // Logits are RAW values that softmax to ~0.998 for the winner.
                // See EntityDecoderSpec header for full conventions.
                var fakeTokens = {
                    "inputIds"      : [ 101, 1850, 3342, 3623, 102 ],
                    "attentionMask" : [ 1, 1, 1, 1, 1 ],
                    "offsetMapping" : [ [0,0], [0,5], [6,14], [15,20], [0,0] ]
                };
                var fakeLogits = [
                    [ 8.0, 0.0, 0.0, 0.0 ],   // CLS  → O
                    [ 0.0, 8.0, 0.0, 0.0 ],   // B-PER
                    [ 0.0, 0.0, 8.0, 0.0 ],   // I-PER
                    [ 8.0, 0.0, 0.0, 0.0 ],   // O "lives"
                    [ 8.0, 0.0, 0.0, 0.0 ]    // SEP  → O
                ];

                var session = new tests.specs.fixtures.MockOnnxSession(
                    tokens = fakeTokens,
                    logits = fakeLogits,
                    loaded = true
                );

                var d = new bxAISentinelONNX.models.OnnxNerDetector( settings: {
                    "session"  : session,
                    "id2label" : { 0: "O", 1: "B-PER", 2: "I-PER", 3: "O" },
                    "labelToSentinel" : { "PER": "PII_PERSON_NAME" }
                } );

                var hits = d.scan( "Alice Martinez lives" );
                expect( hits ).toHaveLength( 1 );
                expect( hits[ 1 ].label ).toBe( "PII_PERSON_NAME" );
                expect( hits[ 1 ].value ).toBe( "Alice Martinez" );
                expect( hits[ 1 ].category ).toBe( "pii-ner" );
                expect( hits[ 1 ].source   ).toBe( "OnnxNerDetector" );
            } );

            it( "returns empty when id2label is empty AND caller didn't override it", function() {
                // Logits / offsets here aren't actually decoded — empty id2label
                // short-circuits scan() before normalization. Cleaned to match
                // the new conventions for consistency with other specs.
                var session = new tests.specs.fixtures.MockOnnxSession(
                    tokens = { "inputIds": [101, 1850, 102], "attentionMask": [1,1,1], "offsetMapping": [[0,0],[0,5],[0,0]] },
                    logits = [ [8.0, 0.0], [0.0, 8.0], [8.0, 0.0] ],
                    loaded = true
                );

                var d = new bxAISentinelONNX.models.OnnxNerDetector( settings: {
                    "session"  : session,
                    "modelName": "not-in-registry",     // forces empty id2label default
                    "id2label" : {}
                } );
                expect( d.scan( "Alice" ) ).toHaveLength( 0 );
            } );

            it( "auto-populates id2label + labelToSentinel from SupportedModels when modelName is registered", function() {
                // piiranha-pii-v1 has a full BIO id2label in the registry.
                var d = new bxAISentinelONNX.models.OnnxNerDetector( settings: {
                    "modelName" : "piiranha-pii-v1",
                    "modelPath" : "/fake/unused/",   // we don't scan, just inspect the resolved maps
                    "session"   : new tests.specs.fixtures.MockOnnxSession( loaded = false )
                } );
                // A scan with an unloaded session returns empty, but if the maps resolved
                // correctly, the detector is ready to work once the session loads.
                // Indirect assertion: set the detector up with a mock session providing real
                // Piiranha-shaped logits and confirm a hit comes through.
                var sess = new tests.specs.fixtures.MockOnnxSession(
                    tokens = { "inputIds": [101, 50, 51, 102], "attentionMask": [1,1,1,1], "offsetMapping": [[0,0],[0,5],[6,12],[0,0]] },
                    // Real Piiranha schema (verified against config.json on
                    // 2026-04-19): 18 labels, IO tagging only, "O" at index 17,
                    // "I-GIVENNAME" at index 7. See SupportedModels.bx
                    // piiranha-pii-v1 entry for the full id2label.
                    logits = [
                        _oneHot( 18, 17 ),   // CLS         → O
                        _oneHot( 18,  7 ),   // I-GIVENNAME (opens)
                        _oneHot( 18,  7 ),   // I-GIVENNAME (extends — IO adjacent merge)
                        _oneHot( 18, 17 )    // SEP         → O (closes span)
                    ],
                    loaded = true
                );

                var d2 = new bxAISentinelONNX.models.OnnxNerDetector( settings: {
                    "modelName" : "piiranha-pii-v1",
                    "session"   : sess
                } );
                var hits = d2.scan( "Alice Martin went home" );
                expect( hits ).toHaveLength( 1 );
                expect( hits[ 1 ].label ).toBe( "PII_PERSON_NAME" );
                expect( hits[ 1 ].value ).toBe( "Alice Martin" );
            } );

        } );

        describe( "OnnxNerDetector — convenience API", function() {

            it( "extractEntities filters by the `types` argument when provided", function() {
                var d = _detectorWithMockHits( [
                    _fakeHit( "PII_PERSON_NAME", "Alice",    1,  5 ),
                    _fakeHit( "PII_EMAIL",       "a@b.c",    7, 11 )
                ] );

                expect( d.extractEntities( "x", [ "PII_EMAIL" ] ) ).toHaveLength( 1 );
                expect( d.extractEntities( "x", [ "PII_EMAIL" ] )[ 1 ].label ).toBe( "PII_EMAIL" );
                expect( d.extractEntities( "x", [] ) ).toHaveLength( 2 );
            } );

            it( "containsPii is true when scan finds anything, false otherwise", function() {
                var dYes = _detectorWithMockHits( [ _fakeHit( "PII_EMAIL", "a@b.c", 1, 5 ) ] );
                expect( dYes.containsPii( "anything" ) ).toBeTrue();

                var dNo = _detectorWithMockHits( [] );
                expect( dNo.containsPii( "anything" ) ).toBeFalse();
            } );

            it( "redactInline replaces every detected span with the replacement text", function() {
                var d = _detectorWithMockHits( [
                    _fakeHit( "PII_PERSON_NAME", "Alice",     1,  5 ),
                    _fakeHit( "PII_EMAIL",       "a@b.c",     7, 11 )
                ] );

                var out = d.redactInline( "Alice a@b.c more", "[X]" );
                expect( out ).toBe( "[X] [X] more" );
            } );

            it( "redactInline accepts a custom replacement and preserves surrounding text", function() {
                var d = _detectorWithMockHits( [ _fakeHit( "PII_PERSON_NAME", "Alice", 10, 14 ) ] );
                var out = d.redactInline( "hello to Alice today", "[PERSON]" );
                expect( out ).toBe( "hello to [PERSON] today" );
            } );

            it( "redactInline returns input unchanged when there are no hits", function() {
                var d = _detectorWithMockHits( [] );
                expect( d.redactInline( "nothing to redact", "[X]" ) ).toBe( "nothing to redact" );
            } );

        } );

        describe( "OnnxNerDetector — real-model integration (gated)", function() {

            // Only runs when `box testbox run labels="real-model"` is specified AND
            // the ONNX Runtime + tokenizer JARs are placed in lib/ AND a model is
            // downloaded to the configured assets directory. Otherwise skipped.
            it( "scans free-form PII through the real GLiNER / Piiranha model", function() {
                var d = new bxAISentinelONNX.models.OnnxNerDetector( settings: {
                    "modelName" : "piiranha-pii-v1",
                    "modelPath" : "./assets/piiranha-pii-v1/",
                    "eagerInit" : true
                } );
                var status = d.validateAssets();
                if ( !status.ok ) {
                    // Intentionally skipped — see spec label. Pass as no-op so the
                    // suite stays green when real model isn't available.
                    return;
                }
                // Test sentence covers Piiranha's RELIABLY-detected entity classes:
                // SSN, credit card, phone. The prior sentences surfaced two
                // documented model limitations (see DEV-NOTES/discovery-log.md):
                //   1. English names in any prose context get tagged "O" with high
                //      confidence — a Piiranha weakness that GLiNER (zero-shot)
                //      would close. Tracked in 07-future-work.md.
                //   2. Emails get fragmented across multiple label types
                //      (sarah=I-EMAIL, johnson=I-USERNAME), so adjacent-merge breaks
                //      and we get only the username portion. Same root cause —
                //      Piiranha's label schema doesn't align cleanly with how email
                //      addresses tokenize via SentencePiece.
                // The spec below asserts only what Piiranha catches with high
                // confidence. Adding GLiNER (or a different NER backend) is the
                // path to closing the name + email gaps.
                var sentence = "Contact Sarah Johnson at sarah.johnson@example.com or call 555-123-4567. Her SSN is 123-45-6789 and credit card is 4532-1234-5678-9010.";
                var hits = d.scan( sentence );

                // Sanity: at least *something* came back.
                expect( arrayLen( hits ) ).toBeGT( 0, "Expected at least one hit, got zero." );

                // Reliably-detected entities. Bidirectional substring matching
                // means "555-123-4567" matches Piiranha's "555-123-4567." (model
                // includes trailing sentence punctuation — known behavior).
                _expectEntity( hits, "555-123-4567",             "PII_PHONE"        );
                _expectEntity( hits, "123-45-6789",              "PII_SSN"          );
                _expectEntity( hits, "4532-1234-5678-9010",      "PII_CREDIT_CARD"  );

                // Negative assertion — pure prose tokens MUST NOT be tagged.
                // Catches the inverted-id2label class of regression.
                _expectNoEntityFor( hits, "Contact" );
                _expectNoEntityFor( hits, "call"    );
                _expectNoEntityFor( hits, "Her"     );

                // Whitespace artifact regression — values must NOT have leading
                // or trailing whitespace. SentencePiece encodes word boundaries
                // into the token, so without an explicit trim in _flushHit, every
                // non-first-content hit comes back as " value" instead of "value".
                for ( var h in hits ) {
                    expect( h.value ).notToMatch( "^\s|\s$",
                        "Hit value '" & h.value & "' has leading or trailing whitespace — _flushHit trim is broken."
                    );
                }
            }, "real-model" );

        } );

    }

    // ─── helpers ─────────────────────────────────────────────────────────

    /**
     * Assert that for the given expected substring + label, at least one hit
     * exists where the substring overlaps the hit's value (in either direction)
     * AND the hit's label matches. Bidirectional overlap so the spec works
     * whether the model produces one wide hit covering the substring or several
     * adjacent hits each covering a fragment of it (IO tagging often does the
     * latter for multi-token entities).
     */
    private void function _expectEntity(
        required array  hits,
        required string substring,
        required string expectedLabel
    ) {
        var matched = false;
        for ( var h in arguments.hits ) {
            if ( h.label != arguments.expectedLabel ) continue;
            if (
                find( arguments.substring, h.value ) > 0
                || find( h.value, arguments.substring ) > 0
            ) {
                matched = true;
                break;
            }
        }
        expect( matched ).toBeTrue(
            "Expected at least one hit with label=" & arguments.expectedLabel
            & " covering substring='" & arguments.substring & "', but none matched. "
            & "Got " & arrayLen( arguments.hits ) & " total hits — see DIAG dump above."
        );
    }

    /**
     * Assert that no hit's value overlaps the given prose token. This catches
     * the inverted-label-map class of bugs where every "O" prediction
     * mis-decodes to a real entity label.
     */
    private void function _expectNoEntityFor(
        required array  hits,
        required string proseToken
    ) {
        for ( var h in arguments.hits ) {
            if ( find( arguments.proseToken, h.value ) > 0 ) {
                fail(
                    "Pure-prose token '" & arguments.proseToken & "' was tagged as "
                    & h.label & " (value='" & h.value & "'). "
                    & "Either the id2label map is wrong (most likely), the offset "
                    & "slicing is wrong, or the confidence floor is too lenient."
                );
            }
        }
    }

    private any function _detectorWithMockHits( required array hits ) {
        var mockSession = new tests.specs.fixtures.MockOnnxSession(
            tokens = { "inputIds": [101, 102], "attentionMask": [1,1], "offsetMapping": [[0,0], [0,0]] },
            logits = [ [ 0.9 ], [ 0.9 ] ],
            loaded = true
        );

        var fakeDecoder = prepareMock( new bxAISentinelONNX.models.EntityDecoder() );
        fakeDecoder.$( "decode", arguments.hits );

        return new bxAISentinelONNX.models.OnnxNerDetector( settings: {
            "session"         : mockSession,
            "decoder"         : fakeDecoder,
            "id2label"        : { 0: "O" },
            "labelToSentinel" : { "DUMMY": "PII_DUMMY" }
        } );
    }

    private struct function _fakeHit( required string label, required string value, required numeric startPos, required numeric endPos ) {
        return {
            "start"      : arguments.startPos,
            "end"        : arguments.endPos,
            "value"      : arguments.value,
            "label"      : arguments.label,
            "category"   : "pii-ner",
            "priority"   : 2,
            "confidence" : 0.99,
            "source"     : "OnnxNerDetector"
        };
    }

    /**
     * Build a one-hot logit vector of size `numLabels` with `hotIndex`
     * bumped to 0.9 and everything else at 0.01. Used to drive deterministic
     * decoder output in the Piiranha auto-population test.
     */
    private array function _oneHot( required numeric numLabels, required numeric hotIndex ) {
        // RAW LOGITS, not probabilities. EntityDecoder applies softmax
        // internally before comparing to confidenceFloor. With 18+ labels,
        // a "0.9 vs 0.01" row softmaxes to ~0.12 — below the default 0.5
        // floor, so every hit gets dropped. Use 8.0 vs 0.0 for the
        // winner-vs-loser pattern; softmax of the winner is ~0.998.
        var row = [];
        for ( var i = 0; i < arguments.numLabels; i++ ) {
            row.append( i == arguments.hotIndex ? 8.0 : 0.0 );
        }
        return row;
    }

}
